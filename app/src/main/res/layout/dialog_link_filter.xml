<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.75"
                android:paddingBottom="8dp"
                android:text="@string/filter_section_seen"
                android:textSize="13sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgSeenFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbSeenAll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_seen_all" />

                <RadioButton
                    android:id="@+id/rbSeenOnlyOpened"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_seen_only_opened" />

                <RadioButton
                    android:id="@+id/rbSeenOnlyUnopened"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_seen_only_unopened" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="?android:attr/listDivider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.75"
                android:paddingBottom="8dp"
                android:text="@string/filter_section_ratings"
                android:textSize="13sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cbRatingNone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rating_none" />

            <CheckBox
                android:id="@+id/cbRatingVeryGood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rating_very_good" />

            <CheckBox
                android:id="@+id/cbRatingGood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rating_good" />

            <CheckBox
                android:id="@+id/cbRatingOkay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rating_okay" />

            <CheckBox
                android:id="@+id/cbRatingBad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rating_bad" />

            <CheckBox
                android:id="@+id/cbRatingVeryBad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/rating_very_bad" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="?android:attr/listDivider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.75"
                android:paddingBottom="8dp"
                android:text="@string/filter_section_sort_by"
                android:textSize="13sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgSortBy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbSortByOriginal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_sort_original" />

                <RadioButton
                    android:id="@+id/rbSortByRating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_sort_rating" />

                <RadioButton
                    android:id="@+id/rbSortByAlphabetical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_sort_url" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="?android:attr/listDivider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.75"
                android:paddingBottom="8dp"
                android:text="@string/filter_section_sort_order"
                android:textSize="13sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgSortOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbSortOrderAsc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_sort_order_asc" />

                <RadioButton
                    android:id="@+id/rbSortOrderDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_sort_order_desc" />
            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/btnFilterReset"
            style="?attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="@string/filter_reset" />

        <Button
            android:id="@+id/btnFilterCancel"
            style="?attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="@string/cancel" />

        <Button
            android:id="@+id/btnFilterApply"
            style="?attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="@string/filter_apply" />
    </LinearLayout>

</LinearLayout>
